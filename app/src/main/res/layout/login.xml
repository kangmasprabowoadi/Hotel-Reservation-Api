<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Logo Amanjiwo -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="309dp"
            android:layout_height="236dp"
            android:layout_marginTop="40dp"
            android:contentDescription="Amanjiwo Logo"
            android:src="@drawable/amanjiwo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Email Field -->
        <LinearLayout
            android:id="@+id/containerEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:backgroundTint="#000000"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/logoImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/person"
                android:tint="#000000" />

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email Address"
                android:inputType="textEmailAddress"
                android:background="@android:color/transparent"
                android:textColor="#000000"
                android:textColorHint="#777777"
                android:padding="4dp"/>
        </LinearLayout>

        <!-- Password Field -->
        <LinearLayout
            android:id="@+id/containerPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/containerEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/gembok"
                android:tint="#" />

            <EditText
                android:id="@+id/editPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Password"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:textColor="#000000"
                android:textColorHint="#777777"
                android:padding="4dp"/>

        </LinearLayout>

        <!-- Remember + Forgot -->
        <LinearLayout
            android:id="@+id/rememberLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="space_between"
            app:layout_constraintTop_toBottomOf="@id/containerPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp">

            <CheckBox
                android:id="@+id/checkRemember"
                android:layout_width="195dp"
                android:layout_height="wrap_content"
                android:text="Remember me?"
                android:textColor="#444444"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textForgot"
                android:layout_width="148dp"
                android:layout_height="wrap_content"
                android:text="Forgot password?"
                android:textAlignment="viewEnd"
                android:textColor="#D4AF37"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Log In Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Log In"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D4AF37"
            app:layout_constraintTop_toBottomOf="@id/rememberLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="20dp"/>

        <!-- Social Container -->
        <LinearLayout
            android:id="@+id/socialContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp">

            <!-- Google -->
            <LinearLayout
                android:id="@+id/btnGoogle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/social_button_border"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/google"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up With Google"
                    android:textColor="#000000"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Facebook -->
            <LinearLayout
                android:id="@+id/btnFacebook"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/social_button_border"
                android:paddingHorizontal="12dp"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="21dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/facebook" />

                <TextView
                    android:layout_width="138dp"
                    android:layout_height="wrap_content"
                    android:text="Sign Up With Facebook"
                    android:textColor="#000000"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sign Up Text -->
        <TextView
            android:id="@+id/textSignup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don’t have an account? Sign Up"
            android:textSize="12sp"
            android:textColor="#444444"
            app:layout_constraintTop_toBottomOf="@id/socialContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:gravity="center"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
